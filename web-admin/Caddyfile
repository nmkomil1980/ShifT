# Edge server for the ShiftFlow web console.
#
# SITE_ADDRESS controls TLS:
#   :80              -> plain HTTP (default; good for local `docker compose up`)
#   localhost        -> HTTPS on :443 via Caddy's internal CA (self-signed)
#   shiftflow.app    -> automatic HTTPS via Let's Encrypt (needs public DNS + 80/443)
{$SITE_ADDRESS::80} {
	encode gzip

	# Security headers.
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https: wss:; script-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'"
		-Server
	}

	# API calls go to the backend container.
	handle /api/* {
		reverse_proxy api:3000
	}

	# Everything else is the single-page app.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
