# Copy to .env and adjust. All variables are optional — with none set the app
# runs on a local SQLite file, which is fine for development.

# --- Database -------------------------------------------------------------
# Set DATABASE_URL to use PostgreSQL instead of SQLite (recommended for
# production / multi-user load). When unset, DATABASE_PATH (SQLite) is used.
# DATABASE_URL=postgresql://postgres:password@localhost:5432/shiftflow
# DATABASE_PATH=./data/shiftflow.db

# --- HTTP -----------------------------------------------------------------
# PORT=3000
# HOST=127.0.0.1
# Comma-separated origins allowed for cross-origin API calls (web/mobile dev):
# CORS_ORIGINS=http://localhost:5173

# --- Sessions -------------------------------------------------------------
# SESSION_DAYS=14

# --- Email -----------------------------------------------------------------
# Base URL of the web app used in email action links (invite/reset/verify).
# APP_URL=https://shiftflow.example.com
# SMTP transport. With no SMTP_HOST, emails are NOT sent — they are logged to
# the console (dev mode), so invitation/reset/verify flows work out of the box.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=secret
# SMTP_FROM=ShiftFlow <no-reply@shiftflow.example.com>

# --- Web Push (VAPID) -----------------------------------------------------
# Generate once with: node -e "console.log(require('web-push').generateVAPIDKeys())"
# If unset, a key pair is generated and persisted to data/vapid.json.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@shiftflow.local
