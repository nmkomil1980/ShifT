# Copy to .env for `docker compose up`. All values have sensible defaults.

# --- Database credentials (used by db + api) ---
POSTGRES_USER=shiftflow
POSTGRES_PASSWORD=change-me
POSTGRES_DB=shiftflow

# --- Edge / TLS ---
# :80            -> plain HTTP on http://localhost (default)
# localhost      -> self-signed HTTPS on https://localhost
# shiftflow.app  -> automatic Let's Encrypt HTTPS (needs public DNS + ports 80/443)
SITE_ADDRESS=:80
HTTP_PORT=80
HTTPS_PORT=443

# --- Web Push (optional; generated & persisted if left blank) ---
# node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@shiftflow.local
